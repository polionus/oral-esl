  "noun_classes": {
    "description": "Rohingya has two noun classes based on animacy. Classifiers attach as suffixes.",
    "NC1": {
      "label": "Animate (humans, animals, plants, manipulated objects like books/pens)",
      "singular_definite_suffix": "-wa",
      "plural_definite_suffix": "-un",
      "singular_indefinite": "ekzon (humans) / uggwa (others)",
      "plural_indefinite": "okkol",
      "examples": [
        {"bare": "manuš", "definite_sg": "manuššwa", "definite_pl": "manuššun", "english": "man"},
        {"bare": "fúl", "definite_sg": "fúllwa", "definite_pl": "fúllun", "english": "flower"},
        {"bare": "holom", "definite_sg": "holommwa", "definite_pl": "holommun", "english": "pen"}
      ]
    },
    "NC2": {
      "label": "Inanimate / abstract nouns",
      "singular_definite_suffix": "-an",
      "plural_definite_suffix": "-un",
      "singular_indefinite": "ekkan",
      "plural_indefinite": "okkol",
      "examples": [
        {"bare": "gór", "definite_sg": "górgan", "definite_pl": "górgun", "english": "house"}
      ]
    }
  },

  "case_system": {
    "cases": [
      {"name": "Absolutive", "marker": "unmarked (bare form)", "function": "Subject of intransitive; indefinite/inanimate object"},
      {"name": "Ergative", "marker": "-e", "function": "Subject of transitive clause (agent)"},
      {"name": "Genitive", "marker": "-r", "function": "Possession ('of')"},
      {"name": "Dative", "marker": "-re", "function": "Indirect object"},
      {"name": "Ablative", "marker": "-ttu", "function": "Movement away, source ('from/to')"},
      {"name": "Locative", "marker": "-t", "function": "Spatial (place) or temporal (time)"},
      {"name": "Benefactive", "marker": "-lla", "function": "Beneficiary ('for')"},
      {"name": "Instrumental", "marker": "-e", "function": "Means of accomplishment ('by')"}
    ]
  },

